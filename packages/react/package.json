{
  "name": "@ai-native/react",
  "version": "0.0.0",
  "description": "React 适配器：受控组件填值、useAIAgent hook、AIBar 组件",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --external react,react-dom,react-router-dom",
    "test": "vitest run"
  },
  "dependencies": {
    "@ai-native/core": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-router-dom": ">=6"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1"
  }
}
