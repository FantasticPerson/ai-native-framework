{
  "name": "@ai-native/scanner",
  "version": "0.0.0",
  "description": "构建时 AST 扫描：从 data-ai-* 标注提取能力清单（manifest）",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/vite.ts --format esm --dts --clean --external vite",
    "test": "vitest run"
  },
  "dependencies": {
    "@ai-native/core": "workspace:*",
    "@babel/parser": "^7.25.6",
    "@babel/traverse": "^7.25.6",
    "@babel/types": "^7.25.6"
  },
  "peerDependencies": {
    "vite": ">=5"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/babel__traverse": "^7.28.0",
    "@types/node": "^20.19.43",
    "vite": "^5.4.8"
  }
}
