{
  "name": "@ai-operable/preset-antd",
  "version": "0.1.0",
  "description": "自动推断预设：从 antd <Form.Item> 静态推断字段清单（名称/标签/类型/选项）",
  "license": "MIT",
  "author": "FantasticPerson",
  "homepage": "https://github.com/FantasticPerson/ai-native-framework#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FantasticPerson/ai-native-framework.git",
    "directory": "packages/preset-antd"
  },
  "bugs": {
    "url": "https://github.com/FantasticPerson/ai-native-framework/issues"
  },
  "keywords": [
    "ai",
    "ai-native",
    "llm",
    "agent",
    "antd",
    "preset",
    "form"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/runtime.ts --format esm --dts --clean",
    "test": "vitest run"
  },
  "dependencies": {
    "@ai-operable/core": "workspace:*",
    "@ai-operable/scanner": "workspace:*",
    "@babel/parser": "^7.25.6",
    "@babel/traverse": "^7.25.6",
    "@babel/types": "^7.25.6"
  },
  "devDependencies": {
    "@types/babel__traverse": "^7.28.0",
    "@types/node": "^20.19.43",
    "jsdom": "^29.1.1"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  }
}
