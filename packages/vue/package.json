{
  "name": "@ai-native/vue",
  "version": "0.0.0",
  "description": "Vue 适配器：原生表单填值、useAIAgent composable、AIBar 组件",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --external vue,vue-router",
    "test": "vitest run"
  },
  "dependencies": {
    "@ai-native/core": "workspace:*"
  },
  "peerDependencies": {
    "vue": ">=3",
    "vue-router": ">=4"
  },
  "devDependencies": {
    "jsdom": "^29.1.1",
    "vue": "^3.5.40",
    "vue-router": "^4.5.0"
  }
}
