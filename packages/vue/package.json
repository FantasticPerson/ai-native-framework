  },
  "peerDependencies": {
    "vue": ">=3",
    "vue-router": ">=4"
  },
  "devDependencies": {
    "jsdom": "^29.1.1",
    "vue": "^3.5.40",
    "vue-router": "^4.5.0"
  },
  "sideEffects": false,
