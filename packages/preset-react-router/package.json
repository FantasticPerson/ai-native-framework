{
  "name": "@ai-native/preset-react-router",
  "version": "0.0.0",
  "description": "自动推断预设：从 react-router 的 <Route> 静态推断模块清单，零改动接入",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
