{
  "compilerOptions": {
    "composite": true,
    "noEmit": false,
    "outDir": "./node_modules/.tmp/tsnode",
    "skipLibCheck": true,
    "target": "ES2020",
    "lib": ["ES2020"],
    "types": ["node"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "strict": true
  },
  "include": ["vite.config.ts", "server"]
}
